+
+const maxJSStreamRead = 64 * 1024
+
+// dial exposes the generic net.Conn seam used by wasm-vm's bounded Worker transport. Unlike
+// fetch, it never constructs an HTTP request or buffers a response body. Each returned method is
+// promise-shaped so blocking Go net.Conn operations run on goroutines instead of the JS callback.
+func (i *jsIPN) dial(network string, args []js.Value) js.Value {
+	return makePromise(func() (any, error) {
+		if len(args) < 2 || args[0].Type() != js.TypeString || args[1].Type() != js.TypeNumber {
+			return nil, fmt.Errorf("Usage: dial%s(host, port[, timeoutMs])", strings.ToUpper(network))
+		}
+		host, port := args[0].String(), args[1].Int()
+		if host == "" || port < 1 || port > 65535 {
+			return nil, fmt.Errorf("invalid destination")
+		}
+		timeout := 10 * time.Second
+		if len(args) >= 3 && args[2].Type() == js.TypeNumber {
+			ms := args[2].Int()
+			if ms > 0 && ms <= 120_000 {
+				timeout = time.Duration(ms) * time.Millisecond
+			}
+		}
+		ctx, cancel := context.WithTimeout(context.Background(), timeout)
+		defer cancel()
+		conn, err := i.dialer.UserDial(ctx, network, net.JoinHostPort(host, strconv.Itoa(port)))
+		if err != nil {
+			return nil, err
+		}
+		return newJSNetConn(conn, network == "udp"), nil
+	})
+}
+
+type jsNetConn struct {
+	conn      net.Conn
+	datagram  bool
+	readMu    sync.Mutex
+	writeMu   sync.Mutex
+	closeOnce sync.Once
+}
+
+func newJSNetConn(conn net.Conn, datagram bool) map[string]any {
+	c := &jsNetConn{conn: conn, datagram: datagram}
+	return map[string]any{
+		"read": js.FuncOf(func(this js.Value, args []js.Value) any {
+			max := maxJSStreamRead
+			if len(args) == 1 && args[0].Type() == js.TypeNumber {
+				max = args[0].Int()
+			}
+			return makePromise(func() (any, error) { return c.read(max) })
+		}),
+		"write": js.FuncOf(func(this js.Value, args []js.Value) any {
+			if len(args) != 1 || !args[0].InstanceOf(js.Global().Get("Uint8Array")) {
+				return rejectedPromise("write requires one Uint8Array")
+			}
+			payload := make([]byte, args[0].Length())
+			js.CopyBytesToGo(payload, args[0])
+			return makePromise(func() (any, error) { return c.write(payload) })
+		}),
+		"shutdownWrite": js.FuncOf(func(this js.Value, args []js.Value) any {
+			return makePromise(func() (any, error) { return nil, c.shutdownWrite() })
+		}),
+		"close": js.FuncOf(func(this js.Value, args []js.Value) any {
+			return makePromise(func() (any, error) { return nil, c.close() })
+		}),
+	}
+}
+
+func (c *jsNetConn) read(max int) (any, error) {
+	if max < 1 || max > maxJSStreamRead {
+		return nil, fmt.Errorf("read size must be between 1 and %d", maxJSStreamRead)
+	}
+	c.readMu.Lock()
+	defer c.readMu.Unlock()
+	buf := make([]byte, max)
+	n, err := c.conn.Read(buf)
+	if err != nil {
+		if err == io.EOF {
+			return nil, nil
+		}
+		return nil, err
+	}
+	array := js.Global().Get("Uint8Array").New(n)
+	js.CopyBytesToJS(array, buf[:n])
+	return array, nil
+}
+
+func (c *jsNetConn) write(payload []byte) (any, error) {
+	if len(payload) > maxJSStreamRead {
+		return nil, fmt.Errorf("write exceeds %d-byte bridge limit", maxJSStreamRead)
+	}
+	c.writeMu.Lock()
+	defer c.writeMu.Unlock()
+	if c.datagram {
+		n, err := c.conn.Write(payload)
+		if err == nil && n != len(payload) {
+			err = io.ErrShortWrite
+		}
+		return n, err
 	}
+	written := 0
+	for written < len(payload) {
+		n, err := c.conn.Write(payload[written:])
+		written += n
+		if err != nil {
+			return written, err
+		}
+		if n == 0 {
+			return written, io.ErrShortWrite
+		}
+	}
+	return written, nil
+}
+
+func (c *jsNetConn) shutdownWrite() error {
+	if c.datagram {
+		return fmt.Errorf("UDP does not support half-close")
+	}
+	if conn, ok := c.conn.(interface{ CloseWrite() error }); ok {
+		return conn.CloseWrite()
+	}
+	return fmt.Errorf("connection does not support half-close")
+}
+
+func (c *jsNetConn) close() (err error) {
+	c.closeOnce.Do(func() { err = c.conn.Close() })
+	return err
+}
+
+func rejectedPromise(message string) js.Value {
+	return js.Global().Get("Promise").Call("reject", message)
 }
 
