# Pinned reference-toolchain versions (E0-T13). Sourced by build.sh, the Dockerfile,
# and the docs. Trace diffing (E0-T20) and golden binaries (E0-T14) are only meaningful
# against these EXACT versions — bump deliberately, never implicitly.

# Base image, pinned by digest (never `latest`).
UBUNTU_DIGEST="ubuntu@sha256:4fbb8e6a8395de5a7550b33509421a2bafbc0aab6c06ba2cef9ebffbc7092d90"

# apt package versions in ubuntu 24.04 (exact, from `apt-cache policy`).
GCC_RISCV64_VERSION="13.2.0-11ubuntu1+12"
QEMU_SYSTEM_MISC_VERSION="1:8.2.2+ds-0ubuntu1.17"

# Spike (riscv-software-src/riscv-isa-sim) built from this commit — no master/HEAD.
SPIKE_COMMIT="55b4658dbf574ba0b714083ec436ce2cb5be1998" # 2026-06-26

# The tag build.sh produces.
IMAGE_TAG="wasm-vm-toolchain:local"
