# Pinned reference-toolchain versions (E0-T13). Sourced by build.sh, the Dockerfile,
# and the docs. Trace diffing (E0-T20) and golden binaries (E0-T14) are only meaningful
# against these EXACT versions — bump deliberately, never implicitly.

# Base image, pinned by digest (never `latest`).
UBUNTU_DIGEST="ubuntu@sha256:4fbb8e6a8395de5a7550b33509421a2bafbc0aab6c06ba2cef9ebffbc7092d90"

# apt package versions in ubuntu 24.04 (exact, from `apt-cache policy`).
# DURABILITY: these pins resolve against Ubuntu's LIVE archive, which prunes superseded
# versions over time. If Ubuntu later supersedes one, the build HARD-FAILS at the
# `apt-get install pkg=version` step (fail-loud, never silent drift) — correct for a
# reference toolchain. For multi-year reproducibility, mirror/snapshot the .deb files
# (e.g. an apt snapshot service) and point the Dockerfile at that.
GCC_RISCV64_VERSION="13.2.0-11ubuntu1+12"
QEMU_SYSTEM_MISC_VERSION="1:8.2.2+ds-0ubuntu1.17"

# Spike (riscv-software-src/riscv-isa-sim) built from this commit — no master/HEAD.
SPIKE_COMMIT="55b4658dbf574ba0b714083ec436ce2cb5be1998" # 2026-06-26

# The tag build.sh produces.
IMAGE_TAG="wasm-vm-toolchain:local"

# riscv-tests suite (E0-T19), pinned with its env submodule. rv64ui-p ELFs are built
# from these exact SHAs by tools/riscv-tests/build.sh and committed under
# tests/riscv-tests-bin/ so the cargo harness runs on a cold clone WITHOUT Docker.
RISCV_TESTS_SHA="34e6b6d1e7936b526075432fb730d89148623484"       # riscv-software-src/riscv-tests
RISCV_TEST_ENV_SHA="6de71edb142be36319e380ce782c3d1830c65d68"    # env submodule
