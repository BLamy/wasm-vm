# E2-T12 kernel config fragment for the wasm-vm virt machine (merged over riscv defconfig
# with scripts/kconfig/merge_config.sh). Why each symbol exists: docs/kernel.md.

# ── Base machine ────────────────────────────────────────────────────────────────
CONFIG_64BIT=y
CONFIG_MMU=y
CONFIG_SOC_VIRT=y
CONFIG_NONPORTABLE=n

# ── Console: SBI earlycon fallback + the E2-T07 16550 as ttyS0 ─────────────────
CONFIG_RISCV_SBI_V01=y
# The SBI earlycon/HVC drivers — `earlycon=sbi` prints via the SBI console before any UART
# binds (exactly the channel our E2-T04 legacy console implements); defconfig leaves these
# off, so a defconfig kernel is SILENT on a serial-less early boot. Required.
CONFIG_SERIAL_EARLYCON=y
CONFIG_SERIAL_EARLYCON_RISCV_SBI=y
CONFIG_HVC_DRIVER=y
CONFIG_HVC_RISCV_SBI=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y

# ── Storage: the E2-T08/T09/T11 virtio-mmio blk stack + ext4 root ───────────────
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_EXT4_FS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_BLK_DEV_INITRD=y

# ── Platform devices from the E2-T01 map ────────────────────────────────────────
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_GOLDFISH=y
CONFIG_RTC_HCTOSYS=y
CONFIG_POWER_RESET=y
CONFIG_POWER_RESET_SYSCON=y
CONFIG_POWER_RESET_SYSCON_POWEROFF=y

# ── Debug aids ──────────────────────────────────────────────────────────────────
CONFIG_PRINTK_TIME=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# ── Everything built-in: no modules, no initramfs/module coupling ──────────────
CONFIG_MODULES=n

# ── Cut boot probing for hardware we don't emulate (Epic 3 revisits networking) ─
CONFIG_PCI=n
CONFIG_NET=n
CONFIG_ETHERNET=n
CONFIG_WLAN=n
CONFIG_USB_SUPPORT=n
CONFIG_SOUND=n
CONFIG_DRM=n
CONFIG_FB=n
