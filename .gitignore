# build artifacts
/target
**/*.rs.bk

# rr traces are evidence, not source — they move via artifact upload, not git
rr-traces/

# python
__pycache__/
*.pyc

# web
node_modules/
dist/
.DS_Store
**/.DS_Store
pkg/

# E0-T23 browser demo build artifacts (regenerated by 'make web-build')
web/node_modules/
web/pkg/
web/assets/*.elf
web/assets/riscv-tests/
.claude/worktrees/
.DS_Store
**/.DS_Store

# E1-T20 RISCOF (provisioned by compliance/provision.sh; not vendored)
compliance/.venv/
compliance/riscv-arch-test/
compliance/riscof_work/
compliance/config.ini

# E1-T21 differential fuzzer scratch (generated .S/.elf per run)
tools/fuzz/.work/

# E1-T26 Sail reference model (downloaded by provision.sh; not vendored)
compliance/sail-riscv/

# E2-T18: the Alpine rootfs ext4 is 512 MiB (sparse ~10 MiB actual) — reproducible from
# `bash tools/build-rootfs.sh` and pinned by releases/rootfs/SHA256SUMS, so it's not tracked.
releases/rootfs/*.ext4
releases/rootfs/MANIFEST.new
